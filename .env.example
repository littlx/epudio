# =========================================================================
# EPUB 有声解读 - 环境变量配置模板
# 复制并命名为 .env，然后填写对应的配置项
# =========================================================================

# -------------------------------------------------------------------------
# DeepSeek API 配置 (必填项)
# -------------------------------------------------------------------------
# 您的 DeepSeek API Key (申请地址: https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek 兼容的 Base URL (如使用官方 API，请保持默认值)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 调用的模型名称 (官方对话模型推荐使用 deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat


# -------------------------------------------------------------------------
# Edge TTS 主持人音色配置 (默认值，可在页面设置中覆盖修改)
# -------------------------------------------------------------------------
# 主持人甲的音色 (默认女声)
VOICE_A=zh-CN-XiaoxiaoNeural

# 主持人乙的音色 (默认男声)
VOICE_B=zh-CN-YunxiNeural


# -------------------------------------------------------------------------
# 解读风格与对话轮数 (默认值，可在页面设置中覆盖修改)
# -------------------------------------------------------------------------
# 解读风格：dialogue (对谈式) / deep (深度解读) / casual (通俗讲解) / storytelling (评书式)
STYLE=dialogue

# 单次生成对谈的最小和最大轮数
TURNS_MIN=8
TURNS_MAX=16


# -------------------------------------------------------------------------
# 性能、限流与并发控制 (默认值，可在页面设置中覆盖修改)
# -------------------------------------------------------------------------
# 后台多章节处理时的并发数 (通常 1~4，推荐为 2，避免超出并发限制)
CONCURRENCY=2

# DeepSeek API 每分钟请求上限 (RPM 限流，避免超出 API 速率限制)
DEEPSEEK_RPM=30

# Edge TTS 的全局最大并发请求上限 (避免请求被微软 Bing 限流拒绝)
EDGE_CONCURRENCY=8


# -------------------------------------------------------------------------
# 系统运行环境配置
# -------------------------------------------------------------------------
# 数据存储目录 (用于存放上传的 EPUB 原文、生成的解读脚本、音频 MP3 与设置信息)
DATA_DIR=./data

# API 后端服务监听的端口号
PORT=8000
